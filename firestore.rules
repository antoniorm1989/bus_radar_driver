rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isDriverSelf(driverId) {
      return isSignedIn() && request.auth.uid == driverId;
    }

    function isAssignedDriver(data) {
      return isSignedIn() &&
          data.assignedDriverRef == /databases/$(database)/documents/drivers/$(request.auth.uid);
    }

    function isAdminRole() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isAssignedDriverForBus(busId) {
      return isSignedIn() &&
          exists(/databases/$(database)/documents/buses/$(busId)) &&
          get(/databases/$(database)/documents/buses/$(busId)).data.assignedDriverRef ==
              /databases/$(database)/documents/drivers/$(request.auth.uid);
    }

    function canModerateBusChat(busId) {
      return isAdminRole() || isAssignedDriverForBus(busId);
    }

    match /busLocations/{busId} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.resource.data.driverId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.driverId == request.auth.uid;
    }

    match /drivers/{driverId} {
      allow read, write: if isDriverSelf(driverId);
    }

    match /buses/{busId} {
      allow read: if true;
      allow create: if isAssignedDriver(request.resource.data);
      allow update, delete: if isAssignedDriver(resource.data);
    }

    match /busChats/{busId} {
      allow read: if isSignedIn();
      allow create, update: if canModerateBusChat(busId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn() &&
            request.resource.data.userId == request.auth.uid &&
            request.resource.data.text is string &&
            request.resource.data.text.size() > 0 &&
            request.resource.data.text.size() <= 700;

        allow update: if (isSignedIn() && request.auth.uid == resource.data.userId) ||
            canModerateBusChat(busId);

        allow delete: if (isSignedIn() && request.auth.uid == resource.data.userId) ||
            canModerateBusChat(busId);
      }
    }
  }
}
